rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/settings/currentFast
    // Fields:
    //   - startTime: number (optional)
    //   - endTime: number (optional)
    //   - status: string (required, ['idle', 'fasting', 'eating'])
    //   - targetHours: number (required, 1-48)
    //   - pausedAt: number (optional)
    //   - totalPausedTime: number (required)
    //   - height: number (optional)
    //   - weight: number (optional)
    //
    // Collection: users/{userId}/history/{recordId}
    // Fields:
    //   - startTime: number (required)
    //   - endTime: number (required)
    //   - duration: number (required)
    //   - targetDuration: number (required)
    //   - completed: bool (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users/{userId}/meals/{mealId}
    // Fields:
    //   - time: number (required)
    //   - scale: string (required, ['light', 'normal', 'large'])
    //   - description: string (optional)
    //   - barcode: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users/{userId}/workouts/{workoutId}
    // Fields:
    //   - startTime: number (required)
    //   - endTime: number (required)
    //   - duration: number (required)
    //   - intensity: string (required, ['low', 'moderate', 'high'])
    //   - type: string (optional, ['cardio', 'strength', 'hiit', 'running', 'walking', 'swimming', 'cycling', 'sports', 'home', 'custom'])
    //   - createdAt: timestamp (required)
    //
    // Collection: users/{userId}/sleep/{sleepId}
    // Fields:
    //   - time: number (required)
    //   - duration: number (required)
    //   - quality: string (required, ['poor', 'fair', 'good', 'excellent'])
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "oshinashok56565656@gmail.com" && 
           (request.auth.token.email_verified == true || !('email_verified' in request.auth.token))) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'lastLogin', 'role']) &&
             data.email is string &&
             data.lastLogin is timestamp &&
             data.role in ['admin', 'client'];
    }

    function isValidFastState(data) {
      return hasRequiredFields(['status', 'targetHours', 'totalPausedTime']) &&
             hasOnlyAllowedFields(['startTime', 'endTime', 'status', 'targetHours', 'targetEndTime', 'pausedAt', 'totalPausedTime', 'height', 'weight', 'sex', 'age', 'waterGoal', 'accentColor']) &&
             data.status in ['idle', 'fasting', 'eating'] &&
             data.targetHours is number && data.targetHours >= 1 && data.targetHours <= 48 &&
             (!('targetEndTime' in data) || data.targetEndTime == null || data.targetEndTime is number) &&
             data.totalPausedTime is number &&
             (!('height' in data) || data.height is number) &&
             (!('weight' in data) || data.weight is number) &&
             (!('sex' in data) || data.sex in ['male', 'female', 'other']) &&
             (!('age' in data) || data.age is number) &&
             (!('waterGoal' in data) || data.waterGoal is number) &&
             (!('accentColor' in data) || data.accentColor is string);
    }

    function isValidFastRecord(data) {
      return hasRequiredFields(['startTime', 'endTime', 'duration', 'targetDuration', 'completed', 'createdAt']) &&
             hasOnlyAllowedFields(['startTime', 'endTime', 'duration', 'targetDuration', 'completed', 'createdAt']) &&
             data.startTime is number &&
             data.endTime is number &&
             data.duration is number &&
             data.targetDuration is number &&
             data.completed is bool &&
             data.createdAt is timestamp;
    }

    function isValidSleep(data) {
      return hasRequiredFields(['bedtime', 'wakeUpTime', 'duration', 'quality', 'createdAt']) &&
             hasOnlyAllowedFields(['bedtime', 'wakeUpTime', 'duration', 'quality', 'createdAt']) &&
             data.bedtime is number &&
             data.wakeUpTime is number &&
             data.duration is number &&
             data.quality in ['poor', 'fair', 'good', 'excellent'] &&
             data.createdAt is timestamp;
    }

    function isValidMeal(data) {
      return hasRequiredFields(['time', 'scale', 'createdAt']) &&
             hasOnlyAllowedFields(['time', 'scale', 'description', 'barcode', 'createdAt']) &&
             data.time is number &&
             data.scale in ['light', 'normal', 'large'] &&
             (!('description' in data) || data.description is string) &&
             (!('barcode' in data) || data.barcode is string) &&
             data.createdAt is timestamp;
    }

    function isValidWorkout(data) {
      return hasRequiredFields(['startTime', 'endTime', 'duration', 'intensity', 'createdAt']) &&
             hasOnlyAllowedFields(['startTime', 'endTime', 'duration', 'intensity', 'type', 'description', 'calorieBurn', 'parsedExercises', 'createdAt']) &&
             data.startTime is number &&
             data.endTime is number &&
             data.duration is number &&
             data.intensity in ['low', 'moderate', 'high'] &&
             (!('type' in data) || data.type in ['cardio', 'strength', 'hiit', 'running', 'walking', 'swimming', 'cycling', 'sports', 'home', 'custom']) &&
             (!('description' in data) || data.description is string) &&
             (!('calorieBurn' in data) || data.calorieBurn is number) &&
             (!('parsedExercises' in data) || data.parsedExercises is list) &&
             data.createdAt is timestamp;
    }

    function isValidWater(data) {
      return hasRequiredFields(['time', 'amount', 'createdAt']) &&
             hasOnlyAllowedFields(['time', 'amount', 'createdAt']) &&
             data.time is number &&
             data.amount is number &&
             data.createdAt is timestamp;
    }

    function isValidWeight(data) {
      return hasRequiredFields(['time', 'weight', 'createdAt']) &&
             hasOnlyAllowedFields(['time', 'weight', 'note', 'createdAt']) &&
             data.time is number &&
             data.weight is number &&
             (!('note' in data) || data.note is string) &&
             data.createdAt is timestamp;
    }

    function isValidMood(data) {
      return hasRequiredFields(['time', 'mood', 'energy', 'createdAt']) &&
             hasOnlyAllowedFields(['time', 'mood', 'energy', 'note', 'tags', 'createdAt']) &&
             data.time is number &&
             data.mood is number && data.mood >= 1 && data.mood <= 5 &&
             data.energy is number && data.energy >= 1 && data.energy <= 5 &&
             (!('note' in data) || data.note is string) &&
             (!('tags' in data) || data.tags is list) &&
             data.createdAt is timestamp;
    }

    function isValidAIInsights(data) {
      return hasRequiredFields(['insights', 'createdAt']) &&
             hasOnlyAllowedFields(['insights', 'calorieGuess', 'caloriesBurned', 'lastRefreshed', 'createdAt']) &&
             data.insights is list &&
             (!('calorieGuess' in data) || data.calorieGuess == null || data.calorieGuess is map) &&
             (!('caloriesBurned' in data) || data.caloriesBurned == null || data.caloriesBurned is map) &&
             (!('lastRefreshed' in data) || data.lastRefreshed == null || data.lastRefreshed is number) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == 'client';
      allow update: if request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();

      match /settings/currentFast {
        allow read: if request.auth.uid == userId || isAdmin();
        allow write: if request.auth.uid == userId || isAdmin();
      }

      match /settings/aiInsights {
        allow read: if request.auth.uid == userId || isAdmin();
        allow write: if (request.auth.uid == userId || isAdmin()) && isValidAIInsights(request.resource.data);
      }

      match /history/{recordId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create, update: if (request.auth.uid == userId || isAdmin()) && isValidFastRecord(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      match /meals/{mealId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create, update: if (request.auth.uid == userId || isAdmin()) && isValidMeal(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      match /workouts/{workoutId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create, update: if (request.auth.uid == userId || isAdmin()) && isValidWorkout(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      match /sleep/{sleepId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create, update: if (request.auth.uid == userId || isAdmin()) && isValidSleep(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      match /water/{waterId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create, update: if (request.auth.uid == userId || isAdmin()) && isValidWater(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      match /weights/{weightId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create, update: if (request.auth.uid == userId || isAdmin()) && isValidWeight(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      match /moods/{moodId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow create, update: if (request.auth.uid == userId || isAdmin()) && isValidMood(request.resource.data);
        allow delete: if request.auth.uid == userId || isAdmin();
      }

      // Catch-all for any other subcollections
      match /{allSubcollections=**} {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
