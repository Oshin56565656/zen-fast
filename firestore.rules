rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/settings/currentFast
    // Fields:
    //   - startTime: number (optional)
    //   - endTime: number (optional)
    //   - status: string (required, ['idle', 'fasting', 'eating'])
    //   - targetHours: number (required, 1-48)
    //   - pausedAt: number (optional)
    //   - totalPausedTime: number (required)
    //   - height: number (optional)
    //   - weight: number (optional)
    //
    // Collection: users/{userId}/history/{recordId}
    // Fields:
    //   - startTime: number (required)
    //   - endTime: number (required)
    //   - duration: number (required)
    //   - targetDuration: number (required)
    //   - completed: bool (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users/{userId}/meals/{mealId}
    // Fields:
    //   - time: number (required)
    //   - scale: string (required, ['snack', 'normal', 'large'])
    //   - description: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users/{userId}/workouts/{workoutId}
    // Fields:
    //   - time: number (required)
    //   - duration: number (required)
    //   - intensity: string (required, ['low', 'moderate', 'high'])
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "oshinashok56565656@gmail.com" && 
           (request.auth.token.email_verified == true || !('email_verified' in request.auth.token)))
        );
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'lastLogin', 'role']) &&
             data.email is string &&
             data.lastLogin is timestamp &&
             data.role in ['admin', 'client'];
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidFastState(data) {
      return hasRequiredFields(['status', 'targetHours', 'totalPausedTime']) &&
             hasOnlyAllowedFields(['startTime', 'endTime', 'status', 'targetHours', 'pausedAt', 'totalPausedTime', 'height', 'weight']) &&
             data.status in ['idle', 'fasting', 'eating'] &&
             data.targetHours is number && data.targetHours >= 1 && data.targetHours <= 48 &&
             data.totalPausedTime is number &&
             (!('height' in data) || data.height is number) &&
             (!('weight' in data) || data.weight is number);
    }

    function isValidFastRecord(data) {
      return hasRequiredFields(['startTime', 'endTime', 'duration', 'targetDuration', 'completed', 'createdAt']) &&
             hasOnlyAllowedFields(['startTime', 'endTime', 'duration', 'targetDuration', 'completed', 'createdAt']) &&
             data.startTime is number &&
             data.endTime is number &&
             data.duration is number &&
             data.targetDuration is number &&
             data.completed is bool &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /settings/currentFast {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /history/{recordId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /meals/{mealId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /workouts/{workoutId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
