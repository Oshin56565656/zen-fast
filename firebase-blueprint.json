{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and integration status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "stravaConnected": { "type": "boolean" },
        "stravaAccessToken": { "type": "string" },
        "stravaRefreshToken": { "type": "string" },
        "stravaTokenExpiresAt": { "type": "number" },
        "stravaAthleteId": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Workout": {
      "title": "Workout",
      "description": "A workout activity from Strava or Strong app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "source": { "type": "string", "enum": ["strava", "strong"] },
        "externalId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "distance": { "type": "number", "description": "Distance in meters" },
        "calories": { "type": "number" },
        "data": { "type": "object", "description": "Raw or source-specific data" }
      },
      "required": ["uid", "source", "startDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings"
    },
    "/users/{userId}/settings/currentFast": {
      "schema": "object",
      "description": "Current fasting state"
    },
    "/users/{userId}/history/{recordId}": {
      "schema": "object",
      "description": "Fasting history records"
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": "object",
      "description": "Meal logs"
    },
    "/users/{userId}/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Workout activities (Strava, Strong, Manual)"
    },
    "/users/{userId}/sleep/{sleepId}": {
      "schema": "object",
      "description": "Sleep logs"
    },
    "/users/{userId}/water/{waterId}": {
      "schema": "object",
      "description": "Water intake logs"
    },
    "/users/{userId}/weights/{weightId}": {
      "schema": "object",
      "description": "Weight tracking logs"
    },
    "/users/{userId}/dailySummaries/{date}": {
      "schema": "object",
      "description": "AI-generated daily summaries"
    }
  }
}
