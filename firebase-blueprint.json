{
  "entities": {
    "UserFastState": {
      "title": "User Fast State",
      "description": "The current fasting state of a user.",
      "type": "object",
      "properties": {
        "startTime": { "type": "number", "description": "Timestamp of when the fast started." },
        "endTime": { "type": "number", "description": "Timestamp of when the fast ended." },
        "status": { "type": "string", "enum": ["idle", "fasting", "eating"], "description": "Current status." },
        "targetHours": { "type": "number", "description": "Target duration in hours." },
        "targetEndTime": { "type": "number", "description": "Specific timestamp to end the fast." },
        "pausedAt": { "type": "number", "description": "Timestamp of when the fast was paused." },
        "totalPausedTime": { "type": "number", "description": "Total time the fast has been paused in ms." },
        "height": { "type": "number", "description": "User height in cm." },
        "weight": { "type": "number", "description": "User weight in kg." },
        "sex": { "type": "string", "enum": ["male", "female", "other"], "description": "User sex." },
        "age": { "type": "number", "description": "User age." },
        "waterGoal": { "type": "number", "description": "User daily water goal in ml." },
        "accentColor": { "type": "string", "description": "Hex code of the user's preferred accent color." }
      },
      "required": ["status", "targetHours", "totalPausedTime"]
    },
    "FastRecord": {
      "title": "Fast Record",
      "description": "A completed fasting session.",
      "type": "object",
      "properties": {
        "startTime": { "type": "number", "description": "Timestamp of start." },
        "endTime": { "type": "number", "description": "Timestamp of end." },
        "duration": { "type": "number", "description": "Total duration in seconds." },
        "targetDuration": { "type": "number", "description": "Target duration in seconds." },
        "completed": { "type": "boolean", "description": "Whether the goal was met." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["startTime", "endTime", "duration", "targetDuration", "completed", "createdAt"]
    },
    "MealRecord": {
      "title": "Meal Record",
      "description": "A log of a meal consumed.",
      "type": "object",
      "properties": {
        "time": { "type": "number", "description": "Timestamp of the meal." },
        "scale": { "type": "string", "enum": ["light", "normal", "large"], "description": "Size of the meal." },
        "description": { "type": "string", "description": "Description of the meal." },
        "barcode": { "type": "string", "description": "Barcode of the meal." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["time", "scale", "createdAt"]
    },
    "WorkoutRecord": {
      "title": "Workout Record",
      "description": "A log of a workout session.",
      "type": "object",
      "properties": {
        "startTime": { "type": "number", "description": "Timestamp of when the workout started." },
        "endTime": { "type": "number", "description": "Timestamp of when the workout ended." },
        "duration": { "type": "number", "description": "Duration in minutes." },
        "intensity": { "type": "string", "enum": ["low", "moderate", "high"], "description": "Intensity level." },
        "type": { "type": "string", "enum": ["cardio", "strength", "hiit", "running", "walking", "swimming", "cycling", "sports", "home", "custom"], "description": "Type of workout." },
        "description": { "type": "string", "description": "Description of the workout (especially for custom workouts)." },
        "calorieBurn": { "type": "number", "description": "Total calories burned (often AI estimated)." },
        "parsedExercises": { "type": "array", "items": { "type": "string" }, "description": "List of recognized exercise names." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["startTime", "endTime", "duration", "intensity", "createdAt"]
    },
    "SleepRecord": {
      "title": "Sleep Record",
      "description": "A log of a sleep session.",
      "type": "object",
      "properties": {
        "bedtime": { "type": "number", "description": "Timestamp of going to bed." },
        "wakeUpTime": { "type": "number", "description": "Timestamp of waking up." },
        "duration": { "type": "number", "description": "Duration in hours." },
        "quality": { "type": "string", "enum": ["poor", "fair", "good", "excellent"], "description": "Quality of sleep." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["bedtime", "wakeUpTime", "duration", "quality", "createdAt"]
    },
    "WaterRecord": {
      "title": "Water Record",
      "description": "A log of water consumption.",
      "type": "object",
      "properties": {
        "time": { "type": "number", "description": "Timestamp of consumption." },
        "amount": { "type": "number", "description": "Amount in ml." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["time", "amount", "createdAt"]
    },
    "WeightRecord": {
      "title": "Weight Record",
      "description": "A log of user weight.",
      "type": "object",
      "properties": {
        "time": { "type": "number", "description": "Timestamp of measurement." },
        "weight": { "type": "number", "description": "Weight in kg." },
        "note": { "type": "string", "description": "Optional note." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["time", "weight", "createdAt"]
    },
    "Supplement": {
      "title": "Supplement",
      "description": "A supplement or medication configuration.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the supplement." },
        "dosage": { "type": "string", "description": "Dosage description." },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "custom"], "description": "Frequency of intake." },
        "preferredTime": { "type": "string", "enum": ["any", "morning", "evening", "with-first-meal", "before-bed"], "description": "Ideal time to take." },
        "reminderEnabled": { "type": "boolean", "description": "Whether reminders are active." },
        "reminderTime": { "type": "string", "description": "Specific time HH:mm for reminder." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["name", "frequency", "preferredTime", "reminderEnabled", "createdAt"]
    },
    "SupplementLog": {
      "title": "Supplement Log",
      "description": "A record of taking a supplement.",
      "type": "object",
      "properties": {
        "supplementId": { "type": "string", "description": "Reference to the Supplement ID." },
        "time": { "type": "number", "description": "Timestamp of ingestion." },
        "taken": { "type": "boolean", "description": "Whether it was marked as taken." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["supplementId", "time", "taken", "createdAt"]
    },
    "AIInsights": {
      "title": "AI Insights",
      "description": "Cached AI coach insights for cross-device synchronization.",
      "type": "object",
      "properties": {
        "insights": { "type": "array", "description": "Array of coaching insights." },
        "calorieGuess": { "type": "object", "description": "AI estimated calorie intake." },
        "caloriesBurned": { "type": "object", "description": "AI estimated calories burned." },
        "lastRefreshed": { "type": "number", "description": "Timestamp of last refresh." },
        "createdAt": { "type": "object", "description": "Firestore server timestamp." }
      },
      "required": ["insights", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/settings/currentFast": {
      "schema": "UserFastState",
      "description": "Stores the user's current fasting state."
    },
    "/users/{userId}/settings/aiInsights": {
      "schema": "AIInsights",
      "description": "Stores cached AI coaching insights for sync."
    },
    "/users/{userId}/history/{recordId}": {
      "schema": "FastRecord",
      "description": "Stores the user's completed fasts."
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": "MealRecord",
      "description": "Stores the user's meal logs."
    },
    "/users/{userId}/workouts/{workoutId}": {
      "schema": "WorkoutRecord",
      "description": "Stores the user's workout logs."
    },
    "/users/{userId}/sleep/{sleepId}": {
      "schema": "SleepRecord",
      "description": "Stores the user's sleep logs."
    },
    "/users/{userId}/water/{waterId}": {
      "schema": "WaterRecord",
      "description": "Stores the user's water logs."
    },
    "/users/{userId}/weights/{weightId}": {
      "schema": "WeightRecord",
      "description": "Stores the user's weight logs."
    },
    "/users/{userId}/supplements/{supplementId}": {
      "schema": "Supplement",
      "description": "Stores the user's supplement configurations."
    },
    "/users/{userId}/supplementLogs/{logId}": {
      "schema": "SupplementLog",
      "description": "Stores the user's daily supplement intake logs."
    }
  }
}
